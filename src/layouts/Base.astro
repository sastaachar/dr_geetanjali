---
import "../styles/global.css";
import { clinic, faqs } from "../data/clinic";

const title = "Dentist in Wanwadi, Pune | Dr. Geetanjali’s Dental Care · Implantology";
const description = `Dentist in Wanwadi, Pune — ${clinic.fullName}. Dental implants, painless root canal, teeth whitening, kids’ dentistry. Rated ${clinic.rating.value}★ (${clinic.rating.count} Google reviews). Open all 7 days. Call ${clinic.phoneDisplay}.`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const dentistSchema = {
  "@context": "https://schema.org",
  "@type": "Dentist",
  "@id": canonical + "#clinic",
  name: clinic.fullName,
  url: canonical,
  telephone: clinic.phoneE164,
  priceRange: "₹₹",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Office No. 205, Aastha Seagull Society, Jambhulkar Chowk",
    addressLocality: "Wanwadi, Pune",
    addressRegion: "Maharashtra",
    postalCode: "411040",
    addressCountry: "IN",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: clinic.geo.lat,
    longitude: clinic.geo.lng,
  },
  hasMap: clinic.address.mapsUrl,
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "10:00",
      closes: "21:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Sunday",
      opens: "11:00",
      closes: "17:00",
    },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: String(clinic.rating.value),
    reviewCount: String(clinic.rating.count),
  },
  sameAs: clinic.profiles,
  areaServed: ["Wanwadi", "Wanowrie", "Salunke Vihar", "Fatima Nagar", "NIBM Road", "Pune Camp", "Pune"],
  medicalSpecialty: "Dentistry",
  founder: {
    "@type": "Person",
    name: clinic.doctor.name,
    jobTitle: clinic.doctor.role,
    alumniOf: "Nair Hospital Dental College, Mumbai",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />
    <meta name="robots" content="index, follow" />
    <meta name="geo.region" content="IN-MH" />
    <meta name="geo.placename" content="Wanwadi, Pune" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={clinic.fullName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_IN" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(dentistSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>
  <body>
    <slot />

    <dialog id="book-modal" aria-labelledby="book-title">
      <div class="book-card">
        <button class="modal-close" aria-label="Close">×</button>
        <p class="eyebrow">Get in touch</p>
        <h3 id="book-title">Book an appointment</h3>
        <div class="book-actions">
          <a class="call-btn" href={`tel:${clinic.phoneE164}`} data-keep-tel>Call {clinic.phoneDisplay}</a>
          <a class="call-btn" href={clinic.whatsapp} target="_blank" rel="noopener">WhatsApp us</a>
          <a class="cta-secondary" href={clinic.address.mapsUrl} target="_blank" rel="noopener">Get directions</a>
        </div>
      </div>
    </dialog>

    <script is:inline define:vars={{ wa: clinic.whatsapp }}>
      // Phones open tel: links natively; on desktops/tablets route calls to WhatsApp instead.
      // Links marked data-keep-tel (the modal already offers WhatsApp separately) are left as-is.
      var canCall = /Android|iPhone/i.test(navigator.userAgent);
      if (!canCall) {
        document.querySelectorAll('a[href^="tel:"]:not([data-keep-tel])').forEach(function (a) {
          a.href = wa;
          a.target = "_blank";
          a.rel = "noopener";
        });
      }

      var modal = document.getElementById("book-modal");
      document.querySelectorAll("[data-book]").forEach(function (btn) {
        btn.addEventListener("click", function () { modal.showModal(); });
      });
      modal.querySelector(".modal-close").addEventListener("click", function () { modal.close(); });
      modal.addEventListener("click", function (e) {
        if (e.target === modal) modal.close();
      });
    </script>
  </body>
</html>
