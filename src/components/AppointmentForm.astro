---
---

<form id="appointment-form" class="appointment-form" novalidate>
  <div class="form-row">
    <label for="appt-name">Name</label>
    <input id="appt-name" name="name" type="text" maxlength="80" required autocomplete="name" />
  </div>
  <div class="form-row">
    <label for="appt-phone">Phone</label>
    <input id="appt-phone" name="phone" type="tel" maxlength="20" required autocomplete="tel" />
  </div>
  <div class="form-row">
    <label for="appt-date">Preferred date</label>
    <input id="appt-date" name="preferredDate" type="date" autocomplete="off" />
  </div>
  <div class="form-row">
    <label for="appt-message">Message (optional)</label>
    <textarea id="appt-message" name="message" maxlength="500" rows="3"></textarea>
  </div>
  <!-- Honeypot field: hidden from real visitors, left blank by them. -->
  <div class="form-row hp-field" aria-hidden="true">
    <label for="appt-company">Company</label>
    <input id="appt-company" name="company" type="text" tabindex="-1" autocomplete="off" />
  </div>
  <button class="call-btn" type="submit">Request appointment</button>
  <p class="form-status" role="status" aria-live="polite"></p>
</form>

<style>
  .appointment-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .form-row label {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .form-row input,
  .form-row textarea {
    font: inherit;
    padding: 0.6rem 0.75rem;
    border: 1px solid #ccc;
    border-radius: 0.5rem;
  }
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .form-status {
    min-height: 1.2em;
    font-size: 0.9rem;
  }
  .form-status[data-state="error"] {
    color: #b00020;
  }
  .form-status[data-state="success"] {
    color: #147a3d;
  }
</style>

<script>
  const form = document.getElementById("appointment-form");
  const status = form?.querySelector(".form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement) || !status) return;

    const submitButton = form.querySelector('button[type="submit"]');
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    submitButton?.setAttribute("disabled", "true");
    status.dataset.state = "";
    status.textContent = "Sending…";

    try {
      const response = await fetch("/api/book-appointment", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        status.dataset.state = "error";
        status.textContent = data.error || "Something went wrong. Please call the clinic instead.";
        return;
      }

      status.dataset.state = "success";
      status.textContent = "Thanks — we'll call you back shortly to confirm.";
      form.reset();
    } catch {
      status.dataset.state = "error";
      status.textContent = "Network error. Please call the clinic instead.";
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>
