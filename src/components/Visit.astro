---
import { clinic } from "../data/clinic";
---

<section id="visit">
  <div class="wrap visit-grid">
    <div>
      <p class="eyebrow">Visit us</p>
      <h2>Find the clinic</h2>
      <address>
        {clinic.address.lines.map((line) => (
          <>{line}<br /></>
        ))}
      </address>
      <div class="cta-row">
        <a class="call-btn" href={clinic.address.mapsUrl} rel="noopener">Get directions</a>
      </div>
    </div>
    <div>
      <p class="eyebrow">Reach us</p>
      <h2>Book an appointment</h2>
      <ul class="contact-list">
        <li><strong>Phone</strong> <a href={`tel:${clinic.phoneE164}`}>{clinic.phoneDisplay}</a></li>
        <li><strong>WhatsApp</strong> <a href={clinic.whatsapp} rel="noopener">Message the clinic</a></li>
        <li><strong>Instagram</strong> <a href={clinic.instagram.url} rel="noopener">{clinic.instagram.handle}</a></li>
        <li><strong>Hours</strong> {clinic.hoursShort}</li>
      </ul>
    </div>
  </div>
</section>
