---
import { Image } from "astro:assets";
import doctor from "../assets/doctor.jpeg";
import { clinic } from "../data/clinic";
---

<section id="about">
  <div class="wrap about-grid">
    <div class="about-side">
      <Image class="portrait" src={doctor} alt={`${clinic.doctor.name} at the clinic`} width={900} />
      <dl class="cred">
        <dt>Qualification</dt>
        <dd>{clinic.doctor.qualification}</dd>
        <dt>Continuing education</dt>
        <dd>Certified in advanced endodontics (Simplified Endodontics)</dd>
        <dt>Focus</dt>
        <dd>Implantology, painless endodontics, family &amp; pediatric dentistry</dd>
        <dt>Patients say</dt>
        <dd>{clinic.rating.value}★ on Google Reviews</dd>
      </dl>
    </div>
    <div class="about-copy">
      <p class="eyebrow">Your dentist</p>
      <h2 class="name">{clinic.doctor.name}</h2>
      <p class="role">{clinic.doctor.role}</p>
      <p>
        {clinic.doctor.name} is a BDS graduate of Nair Hospital Dental College, Mumbai — one of
        India’s top dental institutions — with hands-on hospital training across every branch of
        dental care.
      </p>
      <p>
        Her practice is built on a simple belief: dental treatment shouldn’t be something you
        dread. Patients consistently describe the clinic as caring, hygienic and unhurried — a
        place where every step of treatment is explained before it begins.
      </p>
      <p>
        At her Wanwadi clinic she combines that approach with modern equipment and a special focus
        on implantology, restoring smiles for patients from Wanwadi, Wanowrie, Salunke Vihar,
        Fatima Nagar and across Pune.
      </p>
    </div>
  </div>
</section>
