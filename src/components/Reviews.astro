---
import { clinic, reviews } from "../data/clinic";
---

<section id="reviews">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Patient stories</p>
      <h2>Rated {clinic.rating.value} by our patients</h2>
    </div>
    <div class="quote-grid">
      {reviews.map((r) => (
        <blockquote>
          “{r.quote}”
          <footer>— {r.source}</footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
