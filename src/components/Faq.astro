---
import { faqs } from "../data/clinic";
---

<section id="faq">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">Common questions</p>
      <h2>Frequently asked questions</h2>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
