---
import { clinic } from "../data/clinic";
---

<div class="wrap hero">
  <h1>Gentle, precise dentistry for <em>every smile</em> in the family.</h1>
  <p class="lede">
    Implants, painless root canals and family dentistry by {clinic.doctor.name}, BDS —
    in a modern, spotless clinic at Jambhulkar Chowk.
  </p>
  <div class="cta-row">
    <button class="call-btn" data-book>Book an appointment</button>
  </div>
  <p class="rating">
    <span class="stars" aria-hidden="true">★★★★★</span>
    <strong>{clinic.rating.value}</strong> on Google Reviews
  </p>
  <a class="scroll-cue" href="#results" aria-label="Scroll down to see results">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
  </a>
</div>
